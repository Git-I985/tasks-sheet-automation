{
  "name": "tasks-db",
  "version": "1.0.0",
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@google/clasp": "^3.3.0",
    "@types/bun": "^1.3.14",
    "@types/google-apps-script": "^2.0.11",
    "esbuild": "^0.28.1",
    "typescript": "^6.0.3"
  },
  "description": "Google Apps Script: скрипты файла Tasks",
  "private": true,
  "scripts": {
    "build": "tsc --noEmit && bun run build.ts",
    "format": "biome format --write",
    "lint": "biome lint",
    "check": "biome check --write",
    "push": "bun run build && clasp push -f",
    "deploy": "bun run push && clasp deploy",
    "login": "clasp login",
    "pull": "clasp pull",
    "open": "clasp open-script",
    "logs": "clasp logs"
  },
  "type": "module",
  "dependencies": {
    "date-fns": "^4.4.0"
  }
}
